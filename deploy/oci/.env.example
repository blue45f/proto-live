# ProtoLive OCI 백엔드 .env — `cp .env.example .env` 후 채우기. 절대 커밋하지 말 것.

# ── 인프라 ────────────────────────────────────────────────
DOMAIN=api.proto-live.example.com  # 이 API 서버의 공개 도메인(DNS A 레코드 → VM 공인 IP)
ACME_EMAIL=you@example.com         # Let's Encrypt 알림 메일

# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=protolive
POSTGRES_PASSWORD=                 # 강력한 랜덤 문자열(예: openssl rand -base64 24)
POSTGRES_DB=protolive
# DATABASE_URL 은 compose 가 위 값으로 자동 계산(내부 db 서비스). 직접 설정 불필요.

# ── 앱 ────────────────────────────────────────────────────
PROTOLIVE_SESSION_SECRET=          # 세션 쿠키 서명 키(production 부팅 필수, 예: openssl rand -base64 32)
CORS_ORIGINS=https://proto-live.vercel.app  # 프론트 공개 도메인(쉼표 구분). /api 프록시는 동일출처라 사실상 불필요하지만 명시.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# ── Postgres 튜닝(선택, 인스턴스 리사이즈 시 상향) ─────────
# PG_SHARED_BUFFERS=512MB
# PG_EFFECTIVE_CACHE=2GB
# PG_WORK_MEM=16MB
# PG_MAX_CONN=50
