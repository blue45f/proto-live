# ProtoLive AWS EC2 백엔드 .env — `cp .env.example .env` 후 채우기. 절대 커밋하지 말 것.
# (user-data.sh는 부팅 시 공인 IP로 DOMAIN/시크릿을 자동 생성하므로 보통 직접 편집 불필요.)

# ── 인프라 ────────────────────────────────────────────────
DOMAIN=CHANGE-ME.sslip.io          # 공인 IP 기반 도메인(예: 13-54-1-23.sslip.io). user-data가 자동 설정.
ACME_EMAIL=you@example.com         # Let's Encrypt 알림 메일

# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=protolive
POSTGRES_PASSWORD=                 # 강력한 랜덤(예: openssl rand -base64 24). user-data가 자동 생성.
POSTGRES_DB=protolive
# DATABASE_URL 은 compose 가 위 값으로 자동 계산(내부 db 서비스). 직접 설정 불필요.

# ── 앱 ────────────────────────────────────────────────────
PROTOLIVE_SESSION_SECRET=          # 세션 서명 키(필수, 예: openssl rand -base64 32). user-data가 자동 생성.
CORS_ORIGINS=https://proto-live.vercel.app
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
