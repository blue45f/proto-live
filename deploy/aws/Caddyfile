# Caddy — 자동 HTTPS(Let's Encrypt) 리버스 프록시. {$DOMAIN}(예: <공인IP>.sslip.io)으로 들어온
# 트래픽을 api:3003 으로. Vercel rewrites 가 /api/* 를 https://{$DOMAIN}/api/* 로 보내므로
# 이 서버는 /api 만 처리하면 된다. HTTP-01 챌린지를 위해 보안그룹에서 80/443 인바운드 허용 필요.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip
	reverse_proxy api:3003
	header -Server
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}
