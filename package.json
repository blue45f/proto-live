{
  "name": "proto-live",
  "private": true,
  "version": "1.0.0",
  "description": "ProtoLive — 라이브 프로토타입 투자 매칭 플랫폼 (Vite + NestJS + pnpm monorepo)",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "./scripts/dev.sh",
    "build": "pnpm -r --if-present run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml,html,css}\"",
    "validate:architecture": "node scripts/validate-architecture.mjs",
    "ci": "pnpm run format:check && pnpm run lint:ci && pnpm run typecheck && pnpm run test && pnpm run build",
    "verify": "pnpm run validate:architecture && pnpm run ci",
    "verify:push": "pnpm run verify",
    "sonar": "sonar-scanner",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "sonar:ci": "sonar-scanner -Dsonar.qualitygate.wait=true",
    "smoke": "python3 scripts/smoke_ui.py",
    "seed:demo-data": "pnpm --filter protolive-backend run seed:test-data -- --reset",
    "seed:test-accounts": "pnpm --filter protolive-backend run seed:test-accounts",
    "seed:test-data": "pnpm --filter protolive-backend run seed:test-data",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@heejun/eslint-config": "^4.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  }
}
