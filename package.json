{
  "name": "proto-live",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "ci": "pnpm run verify",
    "smoke": "python3 scripts/smoke_ui.py",
    "seed:demo-data": "pnpm --filter protolive-backend run seed:test-data -- --reset",
    "seed:test-accounts": "pnpm --filter protolive-backend run seed:test-accounts",
    "seed:test-data": "pnpm --filter protolive-backend run seed:test-data"
  }
}
