VITE_API_BASE_URL=http://localhost:3003/api

# desk-platform 공개 문의 게시판(/support) REST 베이스 URL. 미설정 시 라이브 기본값
# (https://desk-platform.vercel.app)로 호출하므로 배포 환경에서는 둘 필요 없다.
# 로컬 개발 시에만 desk-platform api(:6090) 등으로 오버라이드한다.
VITE_DESK_PLATFORM_URL=

# ──────────────────────────────────────────────────────────────────────────
# DeskCloud 네이티브 연동(@heejun/deskcloud 공개 pk_ SDK) — TermsDesk 패턴.
#
# 외부 위젯 임베드가 아니라, 공개 SDK 의 타입드 브라우저 클라이언트로 직접 호출하고
# 화면은 이 앱의 컴포넌트·디자인 토큰으로 렌더한다(네이티브 룩앤필). 각 *_URL 이
# 미설정이면 해당 연동은 비활성이고 앱의 기존 1차 기능으로 폴백한다(가역적·env-gated).
# *_PK 는 선택(미설정 시 'pk_demo' 폴백, publishable 키라 브라우저 노출 안전).
#
# 라이브 엔드포인트는 소스에 박지 않고 아래 예시로만 적어 둔다 — 배포 환경 변수에
# 복사하면 켜진다. 로컬/CI 기본값은 빈 문자열 = 비활성. (secret sk_ 키는 절대 두지 않음.)
# ──────────────────────────────────────────────────────────────────────────

# SurveyDesk — 만족도 설문(문의 페이지 /support 하단에 네이티브 폼). 예: https://surveydesk-api.vercel.app
VITE_SURVEYDESK_URL=
VITE_SURVEYDESK_PK=
# ChangelogDesk — "최근 업데이트"(소개 페이지 /about 안에 네이티브 타임라인). 예: https://changelogdesk-api.vercel.app
VITE_CHANGELOGDESK_URL=
VITE_CHANGELOGDESK_PK=
# ReviewDesk — 후기/평점(소개 페이지 /about 안에 네이티브 카드). 예: https://reviewdesk-api.vercel.app
VITE_REVIEWDESK_URL=
VITE_REVIEWDESK_PK=
# NotifyDesk — 헤더 소식함 벨(로그인 사용자만, 앱 알림 벨과 동일한 네이티브 스타일). 예: https://notifydesk-api.vercel.app
VITE_NOTIFYDESK_URL=
VITE_NOTIFYDESK_PK=
# SearchDesk — 전역 ⌘K/Ctrl+K 검색 팔레트(결과는 SPA 내비게이션, 인앱 `/` 필터와 분리). 예: https://searchdesk-api.vercel.app
VITE_SEARCHDESK_URL=
VITE_SEARCHDESK_PK=

# ──────────────────────────────────────────────────────────────────────────
# 아래 Desk 들은 라이브 엔드포인트가 존재하지만, 이 앱에는 이미 동급 기능이 차별화
# 코어로 들어가 있어 네이티브 연동 대상에서 제외한다(코어 대체 금지 원칙):
#   - CommunityDesk(게시판/카페)   → 프로젝트 토론 허브(DiscussionHub)가 코어
#   - ChatDesk(DM/그룹 채팅)       → 쪽지함(MessagesView)이 코어
#   - MediaDesk(미디어 갤러리)      → 토론/댓글 ImageAttachmentPicker 가 코어
#   - ModerationDesk(신고/모더레이션) → 운영 콘솔 + 후기 신고 플로우가 코어
#   - RealtimeDesk(실시간 프레즌스)  → 프로토타입 라이브 신호 타임라인이 코어
# 예시 라이브 URL(참고용, 현재 미사용):
#   CommunityDesk  https://communitydesk-api.vercel.app
#   ChatDesk       https://16.176.210.195.nip.io/chat
#   MediaDesk      https://16.176.210.195.nip.io/media
#   ModerationDesk https://16.176.210.195.nip.io/moderation
#   RealtimeDesk   https://16.176.210.195.nip.io/realtime
