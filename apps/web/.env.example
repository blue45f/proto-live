VITE_API_BASE_URL=http://localhost:3003/api

# ──────────────────────────────────────────────────────────────────────────
# DeskCloud 위젯 (#49 패턴) — 각 *_URL 미설정 시 해당 위젯은 트리에 마운트되지
# 않아 앱에 어떤 영향도 주지 않는다(가역적·env-gated). *_PK 는 선택(미설정 시
# 'pk_demo' 로 폴백, publishable 키라 브라우저 노출 안전).
#
# 라이브 엔드포인트는 소스에 박지 않고, 아래 예시 값으로만 적어 둔다 — 배포 환경
# 변수에 그대로 복사하면 위젯이 켜진다. 로컬/CI 기본값은 빈 문자열 = 비활성.
# ──────────────────────────────────────────────────────────────────────────

# SurveyDesk — 피드백/설문 플로팅 위젯. 예: https://surveydesk-api.vercel.app
VITE_SURVEYDESK_URL=

# ChangelogDesk — 떠 있는 "새 소식"/변경이력 런처. 예: https://changelogdesk-api.vercel.app
VITE_CHANGELOGDESK_URL=
VITE_CHANGELOGDESK_PK=
# NotifyDesk — 헤더 알림 벨(로그인 사용자만). 예: https://notifydesk-api.vercel.app
VITE_NOTIFYDESK_URL=
VITE_NOTIFYDESK_PK=
# SearchDesk — 전역 ⌘K 검색 팔레트(결과는 SPA 내비게이션으로 이동, 풀 리로드 없음). 예: https://searchdesk-api.vercel.app
VITE_SEARCHDESK_URL=
VITE_SEARCHDESK_PK=
# CommunityDesk — 커뮤니티 게시판 런처(로그인 사용자만). 예: https://communitydesk-api.vercel.app
VITE_COMMUNITYDESK_URL=
VITE_COMMUNITYDESK_PK=
# ChatDesk — 떠 있는 DM/그룹 채팅 런처(로그인 사용자만). 예: https://16.176.210.195.nip.io/chat
VITE_CHATDESK_URL=
VITE_CHATDESK_PK=
# ReviewDesk — 후기/평점 월 런처. 예: https://reviewdesk-api.vercel.app
VITE_REVIEWDESK_URL=
VITE_REVIEWDESK_PK=

# ──────────────────────────────────────────────────────────────────────────
# 아래 3개 Desk 는 라이브 엔드포인트가 존재하지만, 이 앱에는 이미 동급 기능이
# 차별화 코어로 들어가 있어 위젯을 마운트하지 않는다(코어 대체 금지 원칙):
#   - MediaDesk(미디어 갤러리/업로더)        → 토론/댓글의 ImageAttachmentPicker 가 코어
#   - ModerationDesk(신고/콘텐츠 모더레이션)  → 운영 콘솔 + 후기 신고 플로우가 코어
#   - RealtimeDesk(실시간 프레즌스/라이브)    → 프로토타입 라이브 신호 타임라인이 코어
# 필요해지면 변수만 채워 켤 수 있도록 이름만 예약해 둔다(현재 미사용·비활성).
# 예시 라이브 URL:
#   MediaDesk      https://16.176.210.195.nip.io/media
#   ModerationDesk https://16.176.210.195.nip.io/moderation
#   RealtimeDesk   https://16.176.210.195.nip.io/realtime
# VITE_MEDIADESK_URL=
# VITE_MODERATIONDESK_URL=
# VITE_REALTIMEDESK_URL=
