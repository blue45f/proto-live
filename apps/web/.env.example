VITE_API_BASE_URL=http://localhost:3003/api
# SurveyDesk 피드백 위젯 엔드포인트(미설정 시 위젯 비활성). 예: https://surveys.example.com
VITE_SURVEYDESK_URL=

# DeskCloud 위젯(각 *_URL 미설정 시 해당 위젯 비활성). *_PK 는 선택(미설정 시 pk_demo).
# ChangelogDesk — 떠 있는 "새 소식" 런처. 예: https://changelog.example.com
VITE_CHANGELOGDESK_URL=
VITE_CHANGELOGDESK_PK=
# NotifyDesk — 헤더 알림 벨(로그인 사용자만). 예: https://notify.example.com
VITE_NOTIFYDESK_URL=
VITE_NOTIFYDESK_PK=
# SearchDesk — 전역 ⌘K 검색 팔레트. 예: https://search.example.com
VITE_SEARCHDESK_URL=
VITE_SEARCHDESK_PK=
# CommunityDesk — 커뮤니티 게시판 런처(로그인 사용자만). 예: https://community.example.com
VITE_COMMUNITYDESK_URL=
VITE_COMMUNITYDESK_PK=
# ChatDesk — 떠 있는 채팅 런처(로그인 사용자만). 예: https://chat.example.com
VITE_CHATDESK_URL=
VITE_CHATDESK_PK=
# ReviewDesk — 후기 월 런처. 예: https://reviews.example.com
VITE_REVIEWDESK_URL=
VITE_REVIEWDESK_PK=
