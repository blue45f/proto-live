PORT=3003
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
PROJECT_STORE_PATH=./data/protolive-store.json
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
# Set to 1 only behind a trusted reverse proxy (Render/Fly) so rate limiting
# keys on the real client IP from X-Forwarded-For. Off by default to stop a
# direct caller from spoofing XFF to bypass the limit.
RATE_LIMIT_TRUST_PROXY=0
# Required when NODE_ENV=production.
PROTOLIVE_SESSION_SECRET=replace-with-local-random-string
